# --- Copia este archivo como .env y completa tus valores ---
# NUNCA subas el archivo .env real a un repositorio.

# Ruta al log de Suricata
EVE_JSON_PATH=/var/log/suricata/eve.json

# API de Anthropic (GenAI)
ANTHROPIC_API_KEY=tu_api_key_aqui
ANTHROPIC_MODEL=claude-sonnet-4-6

# SMTP para envío de correo
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_password_de_aplicacion
EMAIL_FROM=tu_correo@gmail.com
EMAIL_TO=analista1@empresa.com,analista2@empresa.com

# Comportamiento
DEDUP_WINDOW_MINUTES=10
MIN_SEVERITY=3
WATCHER_LOG=watcher.log
