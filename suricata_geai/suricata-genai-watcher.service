[Unit]
Description=Watcher Suricata + GenAI (analisis automatico de alertas)
After=network.target suricata.service
Wants=suricata.service

[Service]
Type=simple
User=socanalyst
WorkingDirectory=/opt/suricata-genai
EnvironmentFile=/opt/suricata-genai/.env
ExecStart=/usr/bin/python3 /opt/suricata-genai/suricata_genai_watcher.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
